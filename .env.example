# ChirpStack API secret — signs login and API tokens.
# Generate with: openssl rand -base64 32
CHIRPSTACK_API_SECRET=change-me-generate-with-openssl-rand-base64-32

# ChirpStack v4 bootstrap defaults are admin/admin; rotate via UI/CLI after first start.

# API key for the smoke-test script (optional — script falls back to JWT login
# with the default admin/admin credentials if this is a placeholder).
# Create in the ChirpStack UI: Tenant → API Keys → Add.
CHIRPSTACK_API_KEY=change-me-api-key-from-chirpstack-ui

# PostgreSQL password for the chirpstack database user.
POSTGRES_PASSWORD=chirpstack

# Mosquitto credentials for the ChirpStack internal MQTT client
# (integration events and gateway bridge services).
# The mosquitto/entrypoint.sh generates the passwd file from these at startup.
CHIRPSTACK_MQTT_USERNAME=chirpstack
CHIRPSTACK_MQTT_PASSWORD=chirpstack

# Mosquitto credentials for test subscribers (smoke test, research scripts).
MQTT_TEST_USERNAME=testsubscriber
MQTT_TEST_PASSWORD=testsubscriber

# Provisioning app — ChirpStack admin credentials used as fallback when
# CHIRPSTACK_API_KEY is a placeholder. Default values match the ChirpStack
# bootstrap defaults (rotate via ChirpStack UI after first start).
CHIRPSTACK_ADMIN_USER=admin
CHIRPSTACK_ADMIN_PASS=admin

# Provisioning app — ChirpStack tenant, application, and device profile
# names that the provisioning app will find-or-create on first use.
PROVISIONING_TENANT=ChirpStack
PROVISIONING_APPLICATION=WHZ-Stellantriebe
PROVISIONING_PROFILE=WHZ-Stellantrieb-ClassA-OTAA

# Provisioning app — optional HTTP Basic auth.
# Set BOTH vars to non-empty values to enable Basic auth on all routes
# except GET /healthz.  If either is unset or empty the app runs open
# (convenient for local testing; NOT suitable for networked/VPN deployments).
# PROVISIONING_AUTH_USER=
# PROVISIONING_AUTH_PASS=

# Override defaults if the stack runs on remote hosts:
# CHIRPSTACK_HOST=localhost
# MQTT_HOST=localhost
# UDP_HOST=localhost
